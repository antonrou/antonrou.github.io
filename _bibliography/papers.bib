@article{roupassov2025alife,
  abbr        = {A-Life},
  bibtex_show = {true},
  title       = {A Fully Specified, Open-Source Reimplementation of the Ackley \& Littman (1991) Evolutionary Reinforcement Learning A-Life Testbed},
  author      = {Roupassov-Ruiz, Anton and Bulitko, Vadim},
  abstract    = {We present the first fully specified, open-source reimplementation of the classic Ackley and Littman (1991) predator--prey evolutionary reinforcement learning artificial-life testbed. We formulate explainable, differentiable decision lists as a programmatic alternative to black-box neural networks and evaluate policy viability across 4,000 independent trials using Kaplan--Meier survival curves and restricted mean survival time. Programmatic agents significantly outlasted neural networks (log-rank p ~ 4.1e-72), surviving on average 201.69 steps longer (95% CI [180.14, 223.25]).},
  year        = {2025},
  publisher   = {University of Alberta, RLAI Lab},
  url         = {https://github.com/antonrou/erl},
  html        = {https://github.com/antonrou/erl},
  selected    = {true}
}
